{
  "name": "urban-hairplaza",
  "version": "1.0.0",
  "description": "Urban HairPlaza — Multi-vendor salon booking platform with customer, owner, and admin portals.",
  "main": "backend/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "mkdir -p dist && cp -r frontend/customer dist/ && cp -r frontend/owner dist/ && cp -r frontend/admin dist/ && echo 'Frontend build done'",
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "seed": "node backend/db/seed.js",
    "setup-db": "node setup-db.js",
    "sam:build": "sam build",
    "sam:deploy": "sam deploy --guided",
    "sam:deploy:ci": "sam deploy --no-confirm-changeset --no-fail-on-empty-changeset"
  },
  "keywords": [
    "salon",
    "booking",
    "multi-vendor",
    "express",
    "supabase",
    "postgresql",
    "serverless",
    "aws-lambda"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
