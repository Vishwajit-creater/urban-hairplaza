# Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT Secret ─────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ── Database ───────────────────────────────────────────────────────────────
# Path to SQLite DB file (relative to project root)
DB_PATH=backend/db/urban_hairplaza.db

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * only for development)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Admin Default Credentials (used by seed script only) ──────────────────
ADMIN_EMAIL=admin@uhp.com
ADMIN_PASSWORD=Admin@123
